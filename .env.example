# keep Neon credentials secure: do not expose them to client-side code

# Database
DATABASE_URL=

# Authentication (server-side only)
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Application URLs
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app for auth callbacks
NEXT_PUBLIC_BASE_URL=http://localhost:3000 # Base URL exposed to the client

# Media storage (Cloudinary)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# Transactional email (Resend)
RESEND_API_KEY=
